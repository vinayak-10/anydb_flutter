{
  "name": "RKM Physio",
  "description": "Ramakrishna Mission Physiotherapy Database for Daily & Monthly Reports",
  "contents": [
    {
      "type": "aggregator",
      "name": "Daily and Monthly Reports",
      "version": "1.0.0",
      "share": [
        {
          "type": "local"
        },
        {
          "type": "e-mail",
          "url": "kapil.bhavsar@gmail.com"
        },
        {
          "type": "url",
          "url": "https://dwall.xyz/uploadfile/"
        },
        {
          "type": "ftp",
          "url": "ftp://username:password@ftp-server-url/path-to-store/"
        }
      ],
      "schema": [
        {
          "type": "report",
          "name": "Daily",
          "header": {
            "title": "Ramakrishna Mission, Indore",
            "subtitle": "Physiotherapy Center's Daily Report"
          },
          "row": [
            {
              "source": {
                "type": "database",
                "name": "Patients",
                "storage": [
                  {
                    "type": "local"
                  }
                ]
              },
              "columns": [
                "Card Number",
                "Display Name",
                "Sex",
                "Charges",
                "Paid",
                "Discount",
                "Mode",
                "Registered On",
                "Date"
              ],
              "predicates": [
                {
                  "name": "Patients on Date",
                  "operation": "date",
                  "column": "Date",
                  "parameter": {
                    "match": true,
                    "type": "day"
                  }
                },
                {
                  "name": "Sorted by Time",
                  "operation": "sort",
                  "column": "Date",
                  "parameter": {
                    "dir": "asc"
                  }
                },
                {
                  "name": "Convert Registration format",
                  "operation": "convert",
                  "column": "Registered On",
                  "parameter": {
                    "to": "date"
                  }
                },
                {
                  "name": "Convert Date format",
                  "operation": "convert",
                  "column": "Date",
                  "parameter": {
                    "to": "date"
                  }
                }
              ]
            }
          ],
          "summary": [
            {
              "title": "Total Charges",
              "formula": "SUM($Charges.START:$Charges.END)"
            },
            {
              "title": "Total Paid",
              "formula": "SUM($Paid.START:$Paid.END)"
            },
            {
              "title": "Total Cash",
              "formula": "SUMIF($Mode.START:$Mode.END, \"Cash\", $Paid.START:$Paid.END)"
            },
            {
              "title": "Total UPI",
              "formula": "SUMIF($Mode.START:$Mode.END, \"UPI\", $Paid.START:$Paid.END)"
            },
            {
              "title": "Total Transactions",
              "formula": "COUNTA($Mode.START:$Mode.END)"
            },
            {
              "title": "Cash Transactions",
              "formula": "COUNTIF($Mode.START:$Mode.END, \"Cash\")"
            },
            {
              "title": "UPI Transactions",
              "formula": "COUNTIF($Mode.START:$Mode.END, \"UPI\")"
            },
            {
              "title": "Total Discounts",
              "formula": "SUM($Discount.START:$Discount.END)"
            },
            {
              "title": "Free Transactions",
              "formula": "COUNT(FILTER($Discount.START:$Discount.END, $Discount.START:$Discount.END=$Charges.START:$Charges.END))"
            },
            {
              "title": "Male",
              "formula": "IFERROR(ROWS(UNIQUE(FILTER($Card Number.START:$Card Number.END,$Sex.START:$Sex.END=\"Male\"))),0)"
            },
            {
              "title": "Female",
              "formula": "IFERROR(ROWS(UNIQUE(FILTER($Card Number.START:$Card Number.END,$Sex.START:$Sex.END=\"Female\"))),0)"
            },
            {
              "title": "New Patients",
              "formula": "IFERROR(ROWS(UNIQUE(FILTER($Card Number.START:$Card Number.END,$Registered On.START:$Registered On.END=$Date.START))),0)"
            },
            {
              "title": "Existing Patients",
              "formula": "IFERROR(ROWS(UNIQUE(FILTER($Card Number.START:$Card Number.END,$Registered On.START:$Registered On.END<>$Date.START))),0)"
            },
            {
              "title": "Total Patients",
              "formula": "IFERROR(ROWS(UNIQUE($Card Number.START:$Card Number.END)),0)"
            }
          ]
        },
        {
          "type": "report",
          "name": "Monthly",
          "header": {
            "title": "Ramakrishna Mission, Indore",
            "subtitle": "Physiotherapy Center's Monthly Report"
          },
          "row": [
            {
              "source": {
                "type": "report",
                "name": "Daily",
                "storage": [
                  {
                    "type": "local"
                  }
                ]
              },
              "columns": [
                {
                  "title": "Date",
                  "formula": "'Daily'!B4"
                },
                {
                  "title": "Charges",
                  "formula": "'Daily'!A7"
                },
                {
                  "title": "Paid",
                  "formula": "'Daily'!B7"
                },
                {
                  "title": "Cash",
                  "formula": "'Daily'!C7"
                },
                {
                  "title": "UPI",
                  "formula": "'Daily'!D7"
                },
                {
                  "title": "Transactions",
                  "formula": "'Daily'!E7"
                },
                {
                  "title": "Cash Transactions",
                  "formula": "'Daily'!F7"
                },
                {
                  "title": "UPI Transactions",
                  "formula": "'Daily'!G7"
                },
                {
                  "title": "Discounts",
                  "formula": "'Daily'!H7"
                },
                {
                  "title": "Free Transactions",
                  "formula": "'Daily'!I7"
                },
                {
                  "title": "Male",
                  "formula": "'Daily'!J7"
                },
                {
                  "title": "Female",
                  "formula": "'Daily'!K7"
                },
                {
                  "title": "New Patients",
                  "formula": "'Daily'!L7"
                },
                {
                  "title": "Existing Patients",
                  "formula": "'Daily'!M7"
                },
                {
                  "title": "Total Patients",
                  "formula": "'Daily'!N7"
                }
              ],
              "predicates": [
                {
                  "name": "Patients in Month",
                  "operation": "date",
                  "parameter": {
                    "type": "month"
                  }
                }
              ]
            }
          ],
          "summary": [
            {
              "title": "Total Charges",
              "formula": "SUM($Charges.START:$Charges.END)"
            },
            {
              "title": "Total Paid",
              "formula": "SUM($Paid.START:$Paid.END)"
            },
            {
              "title": "Total Cash",
              "formula": "SUM($Cash.START:$Cash.END)"
            },
            {
              "title": "Total UPI",
              "formula": "SUM($UPI.START:$UPI.END)"
            },
            {
              "title": "Total Transactions",
              "formula": "SUM($Transactions.START:$Transactions.END)"
            },
            {
              "title": "Cash Transactions",
              "formula": "SUM($Cash Transactions.START:$Cash Transactions.END)"
            },
            {
              "title": "UPI Transactions",
              "formula": "SUM($UPI Transactions.START:$UPI Transactions.END)"
            },
            {
              "title": "Total Discounts",
              "formula": "SUM($Discounts.START:$Discounts.END)"
            },
            {
              "title": "Free Transactions",
              "formula": "SUM($Free Transactions.START:$Free Transactions.END)"
            },
            {
              "title": "Male",
              "formula": "SUM($Male.START:$Male.END)"
            },
            {
              "title": "Female",
              "formula": "SUM($Female.START:$Female.END)"
            },
            {
              "title": "New Patients",
              "formula": "SUM($New Patients.START:$New Patients.END)"
            },
            {
              "title": "Existing Patients",
              "formula": "SUM($Existing Patients.START:$Existing Patients.END)"
            },
            {
              "title": "Total Patients",
              "formula": "SUM($Existing Patients.START:$Existing Patients.END) + SUM($New Patients.START:$New Patients.END)"
            },
            {
              "title": "Average New Patients",
              "formula": "ROUND(SUM($New Patients.START:$New Patients.END)/COUNTIF($Date.START:$Date.END, \"*\"),0)"
            },
            {
              "title": "Average Exiting Patients",
              "formula": "ROUND(SUM($Existing Patients.START:$Existing Patients.END)/COUNTIF($Date.START:$Date.END, \"*\"),0)"
            },
            {
              "title": "Average Patients",
              "formula": "ROUND((SUM($New Patients.START:$New Patients.END) + SUM($Existing Patients.START:$Existing Patients.END))/COUNTIF($Date.START:$Date.END, \"*\"),0)"
            },
            {
              "title": "Working Days",
              "formula": "COUNTIF($Date.START:$Date.END, \"*\")"
            }
          ]
        }
      ]
    },
    {
      "type": "database",
      "name": "Patients",
      "version": "1.0.0",
      "storage": [
        {
          "type": "local"
        },
        {
          "type": "file"
        },
        {
          "type": "gdrive",
          "folder": "dwall.xyz.genui",
          "file": "genui.json"
        },
        {
          "type": "rest-api",
          "url": "http://dwall.xyz/gendata/add",
          "method": "POST"
        }
      ],
      "authentication": [
        "google",
        "facebook",
        "aadhar",
        "otp"
      ],
      "header": {
        "title": "Ramakrishna Mission, Indore",
        "subtitle": "Physiotherapy Center"
      },
      "meta": {
        "ts": [
          "Registration",
          "Registered On"
        ]
      },
      "events": {
        "actions": [
          {
            "name": "Archive 1 Year Old Registrations",
            "predicates": [
              {
                "type": "match",
                "parameter": {
                  "type": "date",
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "__meta__",
                        "time",
                        "c"
                      ]
                    ]
                  },
                  "predicate": {
                    "before": {
                      "yy": 1,
                      "mm": 0,
                      "dd": 0
                    }
                  }
                }
              },
              {
                "type": "meta",
                "parameter": {
                  "modify": "time.archive"
                }
              },
              {
                "type": "notify",
                "parameter": {
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "Profile",
                        "Display Name"
                      ]
                    ]
                  },
                  "title": "Archived"
                }
              }
            ]
          },
          {
            "name": "Archive non-visitor since 3 months",
            "predicates": [
              {
                "type": "match",
                "parameter": {
                  "type": "date",
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "__meta__",
                        "time",
                        "u"
                      ]
                    ]
                  },
                  "predicate": {
                    "before": {
                      "yy": 0,
                      "mm": 3,
                      "dd": 0
                    }
                  }
                }
              },
              {
                "type": "meta",
                "parameter": {
                  "modify": "time.archive"
                }
              },
              {
                "type": "notify",
                "parameter": {
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "Profile",
                        "Display Name"
                      ]
                    ]
                  },
                  "title": "Archived"
                }
              }
            ]
          },
          {
            "name": "Permanently Remove after 5 Days of deletion",
            "predicates": [
              {
                "type": "match",
                "parameter": {
                  "type": "date",
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "__meta__",
                        "time",
                        "d"
                      ]
                    ]
                  },
                  "predicate": {
                    "before": {
                      "yy": 0,
                      "mm": 0,
                      "dd": 5
                    }
                  }
                }
              },
              {
                "type": "delete"
              },
              {
                "type": "notify",
                "parameter": {
                  "key": {
                    "type": "values",
                    "value": [
                      [
                        "Profile",
                        "Display Name"
                      ]
                    ]
                  },
                  "title": "Deleted"
                }
              }
            ]
          },
          {
            "name": "Update Meta Create & Update time",
            "predicates": [
              {
                "type": "meta",
                "parameter": {
                  "modify": "time.create",
                  "src": {
                    "type": "values",
                    "value": [
                      [
                        "Registration",
                        "Registered On"
                      ]
                    ]
                  }
                }
              },
              {
                "type": "meta",
                "parameter": {
                  "modify": "time.update",
                  "src": {
                    "type": "function",
                    "value": [
                      {
                        "operation": "invoke",
                        "on": "Account",
                        "what": "get-last-transaction-time",
                        "parameters": {
                          "return": "value"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          },
          {
            "name": "Database Backup and Daily Report Generation",
            "predicates": [
              {
                "type": "export",
                "parameter": {
                  "type": "database",
                  "name": "Patients"
                }
              },
              {
                "type": "generate",
                "parameter": {
                  "type": "aggregator",
                  "name": "Daily and Monthly Reports",
                  "param": {
                    "type": "report",
                    "name": "Daily"
                  }
                }
              },
              {
                "type": "generate",
                "parameter": {
                  "type": "aggregator",
                  "name": "Daily and Monthly Reports",
                  "param": {
                    "type": "report",
                    "name": "Monthly"
                  }
                }
              },
              {
                "type": "open"
              }
            ]
          }
        ],
        "onDbStart": [
          "Update Meta Create & Update time",
          "Archive non-visitor since 3 months",
          "Permanently Remove after 5 Days of deletion"
        ],
        "onDbStop": [
          "Database Backup and Daily Report Generation"
        ],
        "onDbEntryAdd": [],
        "onDbEntryUpdate": [],
        "onDbEntryDelete": []
      },
      "schema": [
        {
          "type": "list-header",
          "name": "Patient's Data",
          "title": [
            {
              "type": "values",
              "value": [
                [
                  "Profile",
                  "Display Name"
                ],
                [
                  "Registration",
                  "Card Number"
                ]
              ]
            }
          ],
          "elements": [
            {
              "type": "values",
              "value": [
                [
                  "Medical Data",
                  "Diagnosis"
                ],
                [
                  "Medical Data",
                  "Therapies"
                ]
              ]
            },
            {
              "type": "function",
              "value": [
                {
                  "title": "Mini Account",
                  "content": [
                    {
                      "operation": "invoke",
                      "on": [
                        "Account"
                      ],
                      "what": "get-dues",
                      "parameters": {
                        "return": "display"
                      }
                    },
                    {
                      "operation": "invoke",
                      "on": [
                        "Account"
                      ],
                      "what": "add-one",
                      "parameters": {
                        "return": "display"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "function",
              "value": [
                {
                  "title": "Renewal Info",
                  "content": [
                    {
                      "operation": "invoke",
                      "on": [
                        "Registration",
                        "Renewal"
                      ],
                      "what": "text",
                      "parameters": {
                        "return": "display"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "actions": [
            {
              "type": "function",
              "value": [
                {
                  "title": "Operation",
                  "content": [
                    {
                      "operation": "invoke",
                      "on": [
                        "__meta__"
                      ],
                      "what": "edit",
                      "parameters": {
                        "return": "display"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "composite",
          "name": "Registration",
          "searchable": true,
          "displayGroup": [
            [
              "Card Number",
              "yy",
              "mm"
            ],
            [
              "Registered On"
            ],
            [
              "Renewal"
            ]
          ],
          "elements": [
            {
              "type": "number",
              "name": "Card Number",
              "defaultValue": "",
              "format": "[09999]{/}[00]{/}[099999]",
              "constraint": [
                "non-null"
              ],
              "maxsize": 5,
              "searchable": true
            },
            {
              "type": "meta",
              "fields": [
                "_counter.add.yy",
                "_yy"
              ],
              "separator": "/",
              "name": "yy"
            },
            {
              "type": "meta",
              "fields": [
                "_counter.add.mm",
                "_mm"
              ],
              "separator": "/",
              "name": "mm"
            },
            {
              "type": "dateTime",
              "name": "Registered On",
              "defaultValue": "",
              "mode": "datetime",
              "observers": [
                "mm",
                "yy",
                "Renewal"
              ]
            },
            {
              "type": "reminder",
              "name": "Renewal",
              "defaultValue": {
                "year": "0",
                "month": "1",
                "days": "0"
              }
            }
          ]
        },
        {
          "type": "composite",
          "name": "Profile",
          "searchable": true,
          "displayGroup": [
            [
              "Prefix",
              "Display Name"
            ],
            [
              "Age",
              "Sex"
            ],
            [
              "Contact Number"
            ],
            [
              "Address"
            ]
          ],
          "elements": [
            {
              "type": "multi-select",
              "name": "Prefix",
              "defaultValues": [],
              "limit": 1,
              "allowedValues": [
                "Shri",
                "Shrimati"
              ]
            },
            {
              "type": "text",
              "name": "Display Name",
              "defaultValue": "",
              "searchable": true
            },
            {
              "type": "number",
              "name": "Age",
              "maxsize": 2,
              "defaultValue": ""
            },
            {
              "type": "multi-select",
              "name": "Sex",
              "defaultValues": [],
              "limit": 1,
              "allowedValues": [
                "Male",
                "Female",
                "Others"
              ]
            },
            {
              "type": "phoneNumber",
              "name": "Contact Number",
              "defaultValue": "+91"
            },
            {
              "type": "text",
              "name": "Address",
              "defaultValue": "Indore"
            }
          ]
        },
        {
          "type": "composite",
          "name": "Medical Data",
          "displayGroup": [
            [
              "Therapist"
            ],
            [
              "Diagnosis"
            ],
            [
              "Therapies"
            ],
            [
              "Referred By",
              "Notes"
            ]
          ],
          "elements": [
            {
              "type": "multi-select",
              "name": "Therapist",
              "limit": 1,
              "defaultValues": [
                "Gajendra Singh"
              ],
              "allowedValues": [
                "Gajendra Singh",
                "Suraj Dharve",
                "Komal Patil",
                "Vinita Pancholi"
              ]
            },
            {
              "type": "text",
              "name": "Diagnosis",
              "defaultValue": "Back Pain",
              "multiline": true,
              "lines": 1
            },
            {
              "type": "multi-select",
              "name": "Therapies",
              "defaultValues": [],
              "allowedValues": [
                "Cervical Traction",
                "CPM",
                "Diathermy",
                "EMS",
                "Exercise",
                "HCP",
                "IFT",
                "Infrared",
                "MEMS",
                "Pelvic Traction",
                "TENS",
                "UST",
                "Wax Bath"
              ]
            },
            {
              "type": "text",
              "name": "Referred By",
              "defaultValue": ""
            },
            {
              "type": "text",
              "name": "Notes",
              "defaultValue": "",
              "multiline": true,
              "lines": 3,
              "timed": true
            }
          ]
        },
        {
          "type": "simple-account",
          "name": "Account",
          "version": "1.0.0",
          "config": {
            "notify": [
              {
                "action": "add",
                "duration": 5
              }
            ],
            "overrideTransaction": {
              "keys": [
                "Charges",
                "Paid",
                "Discount"
              ]
            },
            "onEdit": {
              "confirm": true,
              "confirmKeys": [
                "Charges",
                "Paid",
                "Discount"
              ]
            }
          },
          "schema": {
            "type": "composite",
            "name": "Entry",
            "version": "1.0.0",
            "displayGroup": [
              [
                "Date"
              ],
              [
                "Charges",
                "Paid",
                "Discount"
              ],
              [
                "Balance"
              ],
              [
                "Mode"
              ],
              [
                "Notes"
              ]
            ],
            "elements": [
              {
                "type": "dateTime",
                "name": "Date",
                "id": "Transaction-Date",
                "defaultValue": "",
                "mode": "datetime"
              },
              {
                "type": "number",
                "name": "Charges",
                "id": "Debit",
                "defaultValue": "50",
                "observers": [
                  "Paid",
                  "Discount",
                  "Balance"
                ]
              },
              {
                "type": "number",
                "name": "Paid",
                "id": "Credit",
                "defaultValue": "50",
                "observers": [
                  "Discount",
                  "Balance"
                ]
              },
              {
                "type": "number",
                "name": "Discount",
                "id": "Discount",
                "defaultValue": "0",
                "observers": [
                  "Balance"
                ]
              },
              {
                "type": "number",
                "name": "Balance",
                "id": "Balance",
                "defaultValue": "0",
                "access": {
                  "readOnly": true
                }
              },
              {
                "type": "multi-select",
                "name": "Mode",
                "id": "Payment-Mode",
                "limit": 1,
                "min": 1,
                "allowedValues": [
                  "Cash",
                  "UPI"
                ]
              },
              {
                "type": "text",
                "name": "Notes",
                "id": "Transaction-Text",
                "defaultValue": ""
              },
              {
                "type": "text",
                "name": "Particulars",
                "id": "Particulars",
                "defaultValue": ""
              }
            ]
          }
        }
      ]
    }
  ]
}
